# Copie este arquivo para ".env" e preencha os valores.
# NUNCA faca commit do arquivo .env com a chave real.

# Chave da API da Anthropic (Claude). Opcional: o site funciona em modo
# demonstracao (dados mockados) quando a chave nao esta presente.
VITE_ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Identidade da aplicacao
VITE_APP_NAME=DefesaBR Intelligence
VITE_APP_VERSION=1.0.0

# Opcional: chave gratuita da Alpha Vantage (acoes do setor defesa).
# Use "demo" para dados de exemplo.
VITE_ALPHAVANTAGE_KEY=demo
